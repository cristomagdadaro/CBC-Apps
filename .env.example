APP_NAME=Laravel
APP_VERSION=1.12.0
APP_VERSION_MAJOR=1
APP_VERSION_COMMIT_COUNT=0
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1
APP_URL_LOCAL=http://127.0.0.1
DEBUGBAR_ENABLED=false

OUTGOING_TRANSACTION_NOTIFICATION_EMAIL=
EVENT_RESPONSE_NOTIFICATION_EMAIL=

APP_CIPHER=AES-256-CBC

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=reverb
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

REVERB_APP_ID=cbc-apps
REVERB_APP_KEY=cbc-apps-key
REVERB_APP_SECRET=cbc-apps-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_QUEUE=notifications
MAIL_QUEUE=mail
CERTIFICATES_QUEUE=certificates
REALTIME_ENABLED=true
REALTIME_INVENTORY_ENABLED=true
REALTIME_LABORATORY_ENABLED=true
REALTIME_RENTALS_ENABLED=true
REALTIME_CERTIFICATES_ENABLED=true
REALTIME_FORMS_ENABLED=true
REALTIME_RESEARCH_ENABLED=true
REALTIME_CALENDAR_SYNC_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

PYTHON_PATH=python
CERTIFICATE_GENERATOR_PYTHON_HASH_SEED=0
LIBREOFFICE_PATH=soffice

GOOGLE_CALENDAR_SYNC_ENABLED=true
GOOGLE_CALENDAR_AUTH_PROFILE=service_account
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_IMPERSONATE=
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=storage/app/google-calendar/service-account-credentials.json
GOOGLE_CALENDAR_OAUTH_CREDENTIALS_JSON=storage/app/google-calendar/oauth-credentials.json
GOOGLE_CALENDAR_OAUTH_TOKEN_JSON=storage/app/google-calendar/oauth-token.json
GOOGLE_CALENDAR_EVENT_SOURCE_TITLE="OneCBC Portal"
GOOGLE_CALENDAR_TIMEZONE="Asia/Manila"
GOOGLE_CALENDAR_WINDOW_MONTHS_BEFORE=1
GOOGLE_CALENDAR_WINDOW_MONTHS_AFTER=3
